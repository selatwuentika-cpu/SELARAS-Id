            </div>
            <div class="text-center">
                <div class="text-4xl font-bold mb-2" id="my-contributions">0</div>
                <p class="text-sm opacity-90">Kontribusiku</p>
            </div>
        </div>
    </div>

    <!-- Main Features -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-white p-8 rounded-3xl shadow-lg border-b-8 border-red-500 card-hover cursor-pointer" onclick="showSection('komunikasi')">
            <div class="bg-red-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-4">
                <i class="fas fa-heart text-charming-red text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold mb-2 text-charming-red">Bijak Berkomunikasi</h3>
            <p class="text-gray-600 text-sm">Pelajari Kato Nan Ampek dan prinsip komunikasi santun di era digital.</p>
            <div class="mt-4 text-xs text-gray-400">📚 4 Materi • 5 Latihan</div>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-lg border-b-8 border-yellow-500 card-hover cursor-pointer" onclick="showSection('argumen')">
            <div class="bg-yellow-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-4">
                <i class="fas fa-brain text-yellow-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold mb-2">Bijak Berargumentasi</h3>
            <p class="text-gray-600 text-sm">Kuasai metode AREL untuk menyusun argumen yang logis dan meyakinkan.</p>
            <div class="mt-4 text-xs text-gray-400">📚 5 Materi • 3 Latihan</div>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-lg border-b-8 border-purple-500 card-hover cursor-pointer" onclick="showSection('diskusi')">
            <div class="bg-purple-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-4">
                <i class="fas fa-users text-purple-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold mb-2">Ruang Selaras</h3>
            <p class="text-gray-600 text-sm">Berdiskusi sehat, berbagi pemikiran, dan terapkan ilmu komunikasi bersama.</p>
            <div class="mt-4 text-xs text-gray-400">💬 <span id="diskusi-count">0</span> Topik Aktif</div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 bg-soft-purple text-white rounded-3xl shadow-lg flex flex-col justify-between">
            <div>
                <h4 class="text-xl font-bold mb-2">Selesai Belajar?</h4>
                <p class="opacity-90">Uji kemampuanmu dengan Post-Test untuk mengukur peningkatan pemahaman.</p>
            </div>
            <button onclick="showSection('posttest')" class="mt-4 bg-white text-soft-purple px-6 py-2 rounded-lg font-bold hover:bg-gray-100 transition self-start">
                <i class="fas fa-tasks mr-2"></i>Mulai Post-Test
            </button>
        </div>

        <div class="p-6 bg-accent-orange text-white rounded-3xl shadow-lg flex flex-col justify-between">
            <div>
                <h4 class="text-xl font-bold mb-2">Export Data Belajarmu</h4>
                <p class="opacity-90">Download hasil pre-test, post-test, dan kontribusi diskusi ke Excel.</p>
            </div>
            <button onclick="exportToExcel()" class="mt-4 bg-white text-accent-orange px-6 py-2 rounded-lg font-bold hover:bg-gray-100 transition self-start">
                <i class="fas fa-download mr-2"></i>Download Excel
            </button>
        </div>
    </div>
</div>

<!-- KOMUNIKASI SECTION -->
<div id="komunikasi" class="section container mx-auto px-4 py-10">
    <button onclick="showSection('dashboard')" class="mb-6 text-charming-red font-semibold hover:text-red-700">
        <i class="fas fa-arrow-left mr-2"></i>Kembali ke Dashboard
    </button>

    <div class="max-w-4xl">
        <!-- Header -->
