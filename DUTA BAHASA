        </div>

        <!-- Kato Nan Ampek Tabs -->
        <div class="mb-10">
            <div class="flex gap-2 mb-6 flex-wrap">
                <button onclick="showKato('mandaki')" id="tab-mandaki" class="px-6 py-3 bg-charming-red text-white rounded-lg font-semibold transition">Kato Mandaki</button>
