<!-- Scripts -->
<script>
    // ============= DATA STORAGE =============
    let appData = {
        userName: '',
        preTestScore: 0,
        postTestScore: 0,
        discussions: [],
        userContributions: 0,
        startTime: new Date(),
        katoAnswers: {},
        arelBuilds: []
    };

    // ============= UTILITY FUNCTIONS =============
    function showSection(id) {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        window.scrollTo(0, 0);
    }

    function showNotification(message) {
        const notification = document.createElement('div');
        notification.className = 'notification';
        notification.innerHTML = `<i class="fas fa-check-circle mr-2"></i>${message}`;
        document.body.appendChild(notification);
        setTimeout(() => notification.remove(), 3000);
    }

    function showKato(katoType) {
        const katoElements = document.querySelectorAll('[id^="kato-"]');
        const tabButtons = document.querySelectorAll('[id^="tab-"]');
        
        katoElements.forEach(el => el.classList.add('hidden'));
        tabButtons.forEach(btn => btn.classList.remove('bg-charming-red', 'text-white'));
        
        document.getElementById(`kato-${katoType}`).classList.remove('hidden');
        document.getElementById(`tab-${katoType}`).classList.add('bg-charming-red', 'text-white');
    }

    // ============= LOGIN FLOW =============
    function startApp() {
        const nameInput = document.getElementById('user-name');
        if (nameInput.value.trim() === '') {
            alert('Mohon masukkan nama kamu terlebih dahulu! 😊');
            return;
        }
        
        appData.userName = nameInput.value;
        document.getElementById('display-name').textContent = appData.userName;
        document.getElementById('dash-name').textContent = appData.userName;
        document.getElementById('posttest-name').textContent = appData.userName;
        document.getElementById('main-nav').classList.remove('hidden');
        
        showSection('pretest');
    }

    // ============= PRETEST =============
    function submitPretest() {
        const q1 = document.getElementById('pre-q1-correct').checked;
        const q2 = document.getElementById('pre-q2-correct').checked;
        
        let score = 0;
        if(q1) score += 50;
        if(q2) score += 50;
        
        appData.preTestScore = score;
        showNotification(`Pre-Test Selesai! Skor: ${score}/100`);
        showSection('dashboard');
        updateDashboard();
    }

    // ============= POSTTEST =============
    function submitPosttest() {
        const q1 = document.getElementById('post-q1-correct').checked;
        const q2 = document.getElementById('post-q2-correct').checked;
        
        let score = 0;
        if(q1) score += 50;
        if(q2) score += 50;
        
        appData.postTestScore = score;
        const improvement = appData.postTestScore - appData.preTestScore;
        const message = improvement > 0 ? `Post-Test Selesai! Skor: ${score}/100 (↑ +${improvement} poin)` : `Post-Test Selesai! Skor: ${score}/100`;
        
        showNotification(message);
        showSection('dashboard');
        updateDashboard();
    }

    // ============= KOMUNIKASI LATIHAN =============
    function checkKomunikasi(num) {
        const answer = document.getElementById(`answer${num}`).value;
        if(!answer.trim()) {
            alert('Mohon isi jawabanmu terlebih dahulu!');
            return;
        }
        
        appData.katoAnswers[`soal${num}`] = answer;
        alert('✅ Jawaban kamu tercatat! Terima kasih sudah berlatih. 👍');
    }

    // ============= AREL BUILDER =============
    function buildArel() {
        const a = document.getElementById('arel-a').value;
        const r = document.getElementById('arel-r').value;
        const e = document.getElementById('arel-e').value;
        const l = document.getElementById('arel-l').value;
        
        if(!a || !r || !e || !l) {
            alert('Mohon lengkapi semua kolom AREL! 📝');
            return;
        }
        
        const result = `${a} Hal ini dikarenakan ${r}. Sebagai contoh, ${e}. Oleh karena itu, ${l}`;
        document.getElementById('arel-result-text').textContent = result;
        document.getElementById('arel-result-text').classList.remove('italic', 'text-gray-500');
        document.getElementById('arel-result-text').classList.add('text-charming-red', 'font-semibold');
        document.getElementById('copy-arel-btn').classList.remove('hidden');
        
        appData.arelBuilds.push({
            timestamp: new Date(),
            argument: a,
            reason: r,
            example: e,
            link: l,
            full: result
        });
        
        showNotification('Argumen berhasil disusun! 🎉');
    }

    function copyToClipboard() {
        const text = document.getElementById('arel-result-text').textContent;
        navigator.clipboard.writeText(text).then(() => {
            showNotification('Teks sudah disalin ke clipboard! ✂️');
        });
    }

    // ============= DISKUSI SYSTEM =============
    function openMotionModal() {
        document.getElementById('motion-modal').classList.add('active');
    }

    function closeMotionModal() {
        document.getElementById('motion-modal').classList.remove('active');
        document.getElementById('motion-title').value = '';
        document.getElementById('motion-desc').value = '';
    }

    function submitMotion() {
        const title = document.getElementById('motion-title').value;
        const desc = document.getElementById('motion-desc').value;
        
        if(!title.trim() || !desc.trim()) {
            alert('Mohon isi judul dan deskripsi mosi!');
            return;
        }
        
        const motion = {
            id: appData.discussions.length + 1,
            author: appData.userName,
            title: title,
            description: desc,
            timestamp: new Date(),
            likes: 0,
            replies: [],
            liked: false
        };
        
        appData.discussions.push(motion);
        appData.userContributions++;
        
        renderDiskusi();
        closeMotionModal();
        showNotification('Mosi berhasil dibuat! 🎉');
        updateDashboard();
    }

    function renderDiskusi() {
        const diskusiList = document.getElementById('diskusi-list');
        
        if(appData.discussions.length === 0) {
            diskusiList.innerHTML = `
                <div class="text-center py-10 text-gray-500">
                    <i class="fas fa-comments text-5xl mb-3 opacity-30"></i>
                    <p>Belum ada diskusi. Jadilah yang pertama membuat mosi!</p>
                </div>
            `;
            return;
        }
        
        diskusiList.innerHTML = appData.discussions.map((motion, idx) => `
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-charming-red hover:shadow-xl transition">
                <div class="flex justify-between items-start mb-3">
                    <div>
                        <h3 class="text-lg font-bold text-charming-red">${motion.title}</h3>
                        <p class="text-xs text-gray-500">Oleh <span class="font-semibold">${motion.author}</span> • ${new Date(motion.timestamp).toLocaleDateString('id-ID')}</p>
                    </div>
                    <span class="bg-charming-red text-white px-3 py-1 rounded-full text-xs font-bold">${motion.replies.length} Tanggapan</span>
                </div>
                
                <p class="text-gray-700 mb-4">${motion.description}</p>
                
                <div class="flex gap-4 mb-4">
                    <button onclick="toggleLike(${motion.id})" class="flex items-center gap-2 text-charming-red hover:font-bold transition">
                        <i class="fas fa-heart ${motion.liked ? 'text-charming-red' : 'text-gray-400'}"></i>
                        <span>${motion.likes} Suka</span>
                    </button>
                    <button onclick="openReplyModal(${motion.id})" class="flex items-center gap-2 text-gray-600 hover:text-charming-red transition">
                        <i class="fas fa-reply"></i>
                        <span>Balas</span>
                    </button>
                </div>
                
                ${motion.replies.length > 0 ? `
                    <div class="bg-gray-50 p-4 rounded-xl space-y-3 border-t pt-4">
                        ${motion.replies.map((reply, rIdx) => `
                            <div class="flex justify-between items-start">
                                <div class="flex-1">
                                    <p class="text-sm font-semibold text-gray-800">${reply.author}</p>
                                    <p class="text-sm text-gray-700 mt-1">${reply.text}</p>
                                    <p class="text-xs text-gray-400 mt-2">${new Date(reply.timestamp).toLocaleDateString('id-ID')}</p>
                                </div>
                                ${reply.author === appData.userName ? `
                                    <button onclick="deleteReply(${motion.id}, ${rIdx})" class="text-red-500 hover:text-red-700 text-xs">
                                        <i class="fas fa-trash"></i> Hapus
                                    </button>
                                ` : ''}
                            </div>
                        `).join('')}
                    </div>
                ` : ''}
            </div>
        `).join('');
    }

    function toggleLike(motionId) {
        const motion = appData.discussions.find(m => m.id === motionId);
        if(motion) {
            motion.liked = !motion.liked;
            motion.likes += motion.liked ? 1 : -1;
            renderDiskusi();
        }
    }

    let currentReplyMotionId = null;

    function openReplyModal(motionId) {
        currentReplyMotionId = motionId;
        document.getElementById('reply-modal').classList.add('active');
    }

    function closeReplyModal() {
        document.getElementById('reply-modal').classList.remove('active');
        document.getElementById('reply-text').value = '';
        currentReplyMotionId = null;
    }

    function submitReply() {
        const replyText = document.getElementById('reply-text').value;
        
        if(!replyText.trim()) {
            alert('Mohon tulis tanggapanmu!');
            return;
        }
        
        const motion = appData.discussions.find(m => m.id === currentReplyMotionId);
        if(motion) {
            motion.replies.push({
                author: appData.userName,
                text: replyText,
                timestamp: new Date()
            });
            appData.userContributions++;
            renderDiskusi();
            closeReplyModal();
            showNotification('Tanggapan berhasil dikirim! 💬');
            updateDashboard();
        }
    }

    function deleteReply(motionId, replyIdx) {
        if(confirm('Yakin ingin menghapus tanggapan ini?')) {
            const motion = appData.discussions.find(m => m.id === motionId);
            if(motion) {
                motion.replies.splice(replyIdx, 1);
                appData.userContributions--;
                renderDiskusi();
                updateDashboard();
            }
        }
    }

    // ============= DASHBOARD UPDATE =============
    function updateDashboard() {
        const avgScore = (appData.preTestScore + appData.postTestScore) / 2;
        document.getElementById('progress-score').textContent = Math.round(avgScore) + '%';
        document.getElementById('total-posts').textContent = appData.discussions.length;
        document.getElementById('my-contributions').textContent = appData.userContributions;
        document.getElementById('diskusi-count').textContent = appData.discussions.length;
        
        if(appData.discussions.length > 0) {
            document.getElementById('notif-badge').classList.remove('hidden');
            document.getElementById('notif-badge').textContent = appData.discussions.length;
        }
    }

    // ============= EXPORT TO EXCEL =============
    function exportToExcel() {
        // Prepare data
        const data = {
            'Data Peserta': [
                ['Nama', appData.userName],
                ['Tanggal Mulai', new Date(appData.startTime).toLocaleDateString('id-ID')],
                ['Waktu Belajar', Math.round((new Date() - appData.startTime) / 60000) + ' menit']
            ],
            'Hasil Test': [
                ['Pre-Test', appData.preTestScore],
                ['Post-Test', appData.postTestScore],
                ['Peningkatan', appData.postTestScore - appData.preTestScore + ' poin']
            ],
            'Jawaban Kato': Object.entries(appData.katoAnswers).map(([soal, answer]) => [soal, answer]),
            'AREL Builds': appData.arelBuilds.map(build => [
                new Date(build.timestamp).toLocaleDateString('id-ID'),
                build.argument,
                build.reason,
                build.example,
                build.link
            ]),
            'Diskusi': appData.discussions.map(motion => [
                motion.title,
                motion.author,
                new Date(motion.timestamp).toLocaleDateString('id-ID'),
                motion.replies.length,
                motion.likes
            ])
        };

        // Create workbook
        const workbook = XLSX.utils.book_new();
        
        Object.entries(data).forEach(([sheetName, sheetData]) => {
            if(sheetData.length > 0) {
                const worksheet = XLSX.utils.aoa_to_sheet(sheetData);
                XLSX.utils.book_append_sheet(workbook, worksheet, sheetName);
            }
        });

        // Download
        XLSX.writeFile(workbook, `SELARAS_${appData.userName}_${new Date().toISOString().slice(0, 10)}.xlsx`);
        showNotification('File Excel berhasil diunduh! 📊');
    }

    // ============= LOGOUT =============
    function logout() {
        if(confirm('Yakin ingin keluar? Data akan disimpan.')) {
            location.reload();
        }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        renderDiskusi();
    });
</script>

</body>
</html>
