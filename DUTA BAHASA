<!-- ARGUMEN SECTION -->
<div id="argumen" class="section container mx-auto px-4 py-10">
    <button onclick="showSection('dashboard')" class="mb-6 text-charming-red font-semibold hover:text-red-700">
        <i class="fas fa-arrow-left mr-2"></i>Kembali ke Dashboard
    </button>

    <div class="max-w-5xl">
        <!-- Header -->
        <div class="bg-white p-8 rounded-3xl shadow-lg mb-8 border-l-8 border-accent-orange">
            <h2 class="text-4xl font-bold text-charming-red mb-4">🧠 Bijak Berargumentasi</h2>
            <p class="text-gray-700">Berpendapat adalah hak setiap orang, tetapi cara menyampaikan pendapat harus dipikirkan dengan matang. Gunakan metode AREL untuk membuat argumen yang kuat, logis, dan meyakinkan!</p>
        </div>

